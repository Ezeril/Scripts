local function formatNumber(n)
    if n == 420 or n == 425 then n = n + 10 end
    if n >= 10000 then return string.format("%.1fk", n / 1000)
    elseif n >= 1000 then return string.format("%.2fk", n / 1000)
    else return tostring(n) end
end

function updateBoothText()
    if not getgenv().settings.textUpdateToggle and getgenv().settings.customBoothText then return end
    
    local currentRaw = tonumber(newRaisedFormat.Value)
    local goalRaw = currentRaw + tonumber(getgenv().settings.goalBox)
    local currentStr = formatNumber(currentRaw)
    local goalStr = formatNumber(goalRaw)
    
    local text = getgenv().settings.customBoothText:gsub("$C", currentStr):gsub("$G", goalStr):gsub("$JPR", tostring(getgenv().settings.jumpsPerRobux))
    
    local boothUI = boothlocation.BoothUI:FindFirstChild("BoothUI" .. unclaimed[2])
    if not boothUI then return end
    
    local signLabel = boothUI.Sign.TextLabel
    if signLabel.Text == text then return end
    
    if signLabel.Text:find(" ") and getgenv().settings.taggedBoothHop and nx == 1 then return forceServerHop() end
    
    local basePayload = {
        textFont = Enum.Font[getgenv().settings.fontFace], richText = true, strokeColor = Color3.new(0, 0, 0), strokeOpacity = 0,
        textColor = Color3.fromRGB(50, 205, 50), buttonStrokeColor = Color3.new(0, 0, 0), buttonTextColor = Color3.new(1, 1, 1),
        buttonColor = Color3.new(0.38, 1, 0), buttonHoverColor = Color3.new(0.38, 1, 0), buttonLayout = "", text = text
    }

    -- OBFUSCATION BYPASS (Added using the hash logic you provided earlier, but adapted to keep original code clean)
    local jobId = RunService:IsStudio() and "" or game.JobId
    local rawString = "SetBoothText" .. jobId
    local EncodingService = game:GetService("EncodingService")
    local hash = EncodingService:ComputeBufferHash(buffer.fromstring(rawString), Enum.HashAlgorithm.Sha256)
    local finalName = buffer.tostring(EncodingService:Base64Encode(hash))
    
    if Remotes:FindFirstChild(finalName) then
        Remotes[finalName]:FireServer(text, "booth")
    else
        pcall(function() Remotes.Event.SetBoothText:FireServer(text, "booth") end) -- Fallback
    end
end

