    if WEBHOOK_URL and WEBHOOK_URL ~= "" then
        task.spawn(function()
            local req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
            if req then
                local executorName = identifyexecutor and identifyexecutor() or "Unknown Executor"
                local hwid = "Unknown"; pcall(function() hwid = gethwid and gethwid() or game:GetService("RbxAnalyticsService"):GetClientId() end)
                local accountAge = player.AccountAge; local avatarUrl = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. player.UserId .. "&width=420&height=420&format=png"
                local data = {
                    ["embeds"] = {{
                        ["title"] = "🚀 Comet Hub Executed!",
                        ["description"] = "**Player Profile:** [Click Here](https://www.roblox.com/users/" .. player.UserId .. "/profile)\n**Game:** [Pls Donate](https://www.roblox.com/games/".. game.PlaceId ..")",
                        ["color"] = 16777215, ["thumbnail"] = { ["url"] = avatarUrl },
                        ["fields"] = {
                            {["name"] = "👤 Player", ["value"] = "```" .. player.Name .. " (@" .. player.DisplayName .. ")```", ["inline"] = true},
                            {["name"] = "🆔 User ID", ["value"] = "```" .. tostring(player.UserId) .. "```", ["inline"] = true},
                            {["name"] = "💻 Executor", ["value"] = "```" .. executorName .. "```", ["inline"] = true},
                            {["name"] = "🌐 Job ID", ["value"] = "```" .. tostring(game.JobId) .. "```", ["inline"] = false}
                        },
                        ["timestamp"] = DateTime.now():ToIsoDate()
                    }}
                }
                pcall(function() req({ Url = WEBHOOK_URL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data) }) end)
            end
        end)
    end

    -- Visual Loading Sequence (Independent of Game Events)
    tween(BarFill, {Size = UDim2.new(0.35, 0, 1, 0)}, 0.8); task.wait(0.8); LoadText.Text = "Loading UI..."
    tween(BarFill, {Size = UDim2.new(0.75, 0, 1, 0)}, 1.0); task.wait(1.0); LoadText.Text = "Applying Settings..."
    tween(BarFill, {Size = UDim2.new(1, 0, 1, 0)}, 0.6); task.wait(0.6); LoadText.Text = "Welcome to Comet Hub!"; LoadText.TextColor3 = C.white; task.wait(0.6)

    tween(LoadFrame, {Size = UDim2.new(0, 280, 0, 140), BackgroundTransparency = 1}, 0.3)
    for _, v in pairs(LoadFrame:GetDescendants()) do
        if v:IsA("TextLabel") then tween(v, {TextTransparency = 1}, 0.3) elseif v:IsA("ImageLabel") then tween(v, {ImageTransparency = 1}, 0.3) elseif v:IsA("Frame") then tween(v, {BackgroundTransparency = 1}, 0.3) elseif v:IsA("UIStroke") then tween(v, {Transparency = 1}, 0.3) end
    end
    task.wait(0.3); LoadFrame:Destroy()

    Win.Size = UDim2.new(0, 500, 0, 360); Win.Visible = true; tween(Win, {Size = UDim2.new(0, 560, 0, 420)}, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    -- BACKGROUND LOGIC: Claiming Booth & Walking
    task.spawn(function()
        local _shuffled = workspace:FindFirstChild('MapUI')
        if not _shuffled then pcall(function() _boothlocation = player.PlayerGui:WaitForChild('MapUIContainer', 5):WaitForChild('MapUI', 5) end) else _boothlocation = _shuffled end
        if not _boothlocation then return end

        local function findUnclaimed()
            unclaimed = {}
            local boothUI = _boothlocation:WaitForChild("BoothUI", 5)
            local interactions = workspace:WaitForChild("BoothInteractions", 5)
            if not boothUI or not interactions then return end

            local mainPos2D = Vector3.new(mainCheckPosition.X, 0, mainCheckPosition.Z)
            
            for _, uiFrame in ipairs(boothUI:GetChildren()) do
                if uiFrame:FindFirstChild("Details") and uiFrame.Details:FindFirstChild("Owner") then
                    if string.find(uiFrame.Details.Owner.Text, player.DisplayName) or string.find(uiFrame.Details.Owner.Text, player.Name) then
                        bclaimed = true
                        local bNum = tonumber(uiFrame.Name:match("%d+"))
                        if bNum then unclaimed[2] = bNum end
                        return true
                    end
                end
            end

            if not bclaimed then
                for _, uiFrame in ipairs(boothUI:GetChildren()) do
                    if uiFrame:FindFirstChild("Details") and uiFrame.Details:FindFirstChild("Owner") and uiFrame.Details.Owner.Text == "unclaimed" then
                        local boothNum = tonumber(uiFrame.Name:match("%d+"))
                        if boothNum then
                            for _, interact in ipairs(interactions:GetChildren()) do
                                if interact:GetAttribute("BoothSlot") == boothNum then
                                    local pos2D = Vector3.new(interact.Position.X, 0, interact.Position.Z)
                                    if (pos2D - mainPos2D).Magnitude < 92 then
                                        unclaimed[2] = boothNum
                                        return false
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end

        pcall(findUnclaimed)

        if unclaimed[2] and not bclaimed then
            pcall(function() Remotes.Event("ClaimBooth"):InvokeServer(unclaimed[2]) end)
            task.wait(0.5)
            pcall(function()
                local theCframe = CFrame.new(0, 0, Settings.boothPosition)
                local boothPos
                for _, v in ipairs(workspace.BoothInteractions:GetChildren()) do
                    if v:GetAttribute("BoothSlot") == unclaimed[2] then
                        boothPos = v.CFrame * theCframe
                        player.Character.HumanoidRootPart.CFrame = v.CFrame
                        break
                    end
                end
                if boothPos and player.Character then
                    player.Character.Humanoid.WalkSpeed = 32
                    player.Character.Humanoid:MoveTo(boothPos.Position)
                    task.wait(1.5) -- Instead of repeat loop, just wait a fixed short time for safety
                    player.Character.Humanoid.RootPart.CFrame = CFrame.new(boothPos.Position)
                    player.Character.Humanoid.WalkSpeed = 16
                    bclaimed = true
                end
            end)
        end
        updateBoothText()
    end)

    -- BACKGROUND LOGIC: Leaderstats Listeners
    task.spawn(function()
        if newRaisedFormat then
            local RaisedC = newRaisedFormat.Value
            newRaisedFormat.Changed:Connect(function()
                local raised = newRaisedFormat.Value - RaisedC
                
                if Settings.spinSet and player.Character then
                    local root = player.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        local spinPart = root:FindFirstChild('Spin') or Instance.new("BodyAngularVelocity", root)
                        spinPart.Name = "Spin"; spinPart.MaxTorque = Vector3.new(0, math.huge, 0)
                        xspin = ((raised/3) * Settings.spinSpeedMultiplier) + (spinPart.AngularVelocity.Y or 0)
                        spinPart.AngularVelocity = Vector3.new(0, xspin, 0)
                    end
                end
                
                if Settings.donationJump and player.Character then
                    task.spawn(function()
                        for i = 1, raised * Settings.jumpsPerRobux do
                            player.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                            task.wait(0.6)
                        end
                    end)
                end

                if Settings.helicopterEnabled and player.Character then
                    task.spawn(function()
                        local root = player.Character.Humanoid.RootPart
                        local heli = Instance.new("BodyAngularVelocity", root)
                        heli.Name = "HL1__HELI"; heli.MaxTorque = Vector3.new(0, math.huge, 0); heli.AngularVelocity = Vector3.new(0, 25, 0)
                        local base = Instance.new('Part', workspace)
                        base.Size = Vector3.new(20,2,20); base.Anchored = true; base.CFrame = CFrame.new(root.Position - Vector3.new(0, 3, 0))
                        task.wait(3); tween(base, {CFrame = base.CFrame + Vector3.new(0, raised * 5, 0)}, 10)
                        task.wait(10); base:Destroy(); heli:Destroy()
                    end)
                end
                
                if Settings.autoThanks then
                    task.spawn(function()
                        task.wait(Settings.thanksDelay)
                        local tMsgs = splitString(Settings.thanksMessage)
                        if #tMsgs > 0 then chatMsg(tMsgs[math.random(#tMsgs)]) end
                    end)
                end
                
                RaisedC = newRaisedFormat.Value
                task.wait(Settings.textUpdateDelay)
                updateBoothText()
            end)
        end
    end)
end)

-- AUTO REPLIES LISTENER
Players.PlayerChatted:Connect(function(_, p, message)
    if not Settings.autoNearReply or p == player then return end
    local msg = string.lower(message)
    local pChar = p.Character
    if pChar and pChar:FindFirstChild("HumanoidRootPart") and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        if (pChar.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude < 15 then
            local reply = nil
            if string.find(msg, 'hello') or string.find(msg, 'hi ') then
                local r = splitString(Settings.helloResponce); reply = r[math.random(#r)]
            elseif string.find(msg, 'bot') then
                local r = splitString(Settings.botResponce); reply = r[math.random(#r)]
            elseif string.find(msg, 'donate') then
                local r = splitString(Settings.donateResponce); reply = r[math.random(#r)]
            elseif string.find(msg, 'scam') then
                local r = splitString(Settings.scamResponce); reply = r[math.random(#r)]
            end
            if reply then task.wait(2.1 + math.random()); chatMsg(reply) end
        end
    end
end)
