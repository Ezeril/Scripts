local function webhook(raised, donor)
    local url = getgenv().settings.webhookBox:match("%S+")
    if not url or url == "" then return end
    local embed = {
        title = player.Name .. " 💸 just got donated!",
        description = string.format("**%d R$** by **%s**\n• A/T: %d R$\n• Total: %d R$", raised, donor, math.floor(raised * 0.6), tonumber(player.leaderstats.Raised.Value)),
        color = 0x2ECC71,
        thumbnail = {url = ("https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=256&height=256&format=png"):format(player.UserId)},
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
    }
    httprequest({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode({embeds = {embed}})})
    if getgenv().settings.pingEveryone and raised >= tonumber(getgenv().settings.pingAboveDono) then
        httprequest({Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode({content = "@everyone"})})
    end
end

