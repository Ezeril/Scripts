        if not alreadyClaimed then
            LoadText.Text = "No booths found, hopping..."
            task.wait(1)
            forceServerHop()
            return
        end
    else
        -- Original Claim Logic
        LoadText.Text = "Claiming booth..."
        local function boothclaim()
            -- Obfuscated Claim Fire (same logic as before)
            local jobId = RunService:IsStudio() and "" or game.JobId
            local EncodingService = game:GetService("EncodingService")
            local hash = EncodingService:ComputeBufferHash(buffer.fromstring("ClaimBooth" .. jobId), Enum.HashAlgorithm.Sha256)
            local finalName = buffer.tostring(EncodingService:Base64Encode(hash))
            
            if Remotes:FindFirstChild(finalName) then
                Remotes[finalName]:InvokeServer(unclaimed[2])
            else
                Remotes.Event.ClaimBooth:InvokeServer(unclaimed[2])
            end
            
            task.wait(1)
            if not string.find(boothlocation.BoothUI:FindFirstChild(tostring("BoothUI" .. unclaimed[2])).Details.Owner.Text, Players.LocalPlayer.DisplayName) then
                error()
            end
        end
        
        while not pcall(boothclaim) do
            if errCount >= claimCount then forceServerHop() end
            table.remove(unclaimed, 1)
            errCount = errCount + 1
        end
        
        -- Walk to Booth
        local theCframe = CFrame.new(0, 0, 3)
        local boothPos, mainPosX
        for i, v in ipairs(workspace.BoothInteractions:GetChildren()) do
            if v:GetAttribute("BoothSlot") == unclaimed[2] then
                mainPosX = v.CFrame
                boothPos = v.CFrame * theCframe
                break
            end
        end
        
        if boothPos then
            Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(boothPos.Position)
        end
    end

    tween(BarFill, {Size = UDim2.new(1, 0, 1, 0)}, 0.5)
    task.wait(0.5); LoadText.Text = "Complete!"; task.wait(0.5)
    
    LoadFrame:Destroy()
    Win.Visible = true
    
    task.wait(getgenv().settings.textUpdateDelay)
    updateBoothText()
end)

