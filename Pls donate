Players.PlayerChatted:Connect(function(_, p, message)
    if not getgenv().settings.autoNearReply or p == player or string.find(string.lower(message), "donates") then return end
    local msg = string.lower(message)
    local pChar = p.Character
    if pChar and pChar:FindFirstChild("HumanoidRootPart") and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        if (pChar.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude < 15 then
            if p:GetAttribute('respcd') then return end
            pcall(function()
                p:SetAttribute('respcd', true)
                local reply = nil
                if string.find(msg, 'hello') or string.find(msg, 'hi ') then
                    local r = type(getgenv().settings.helloResponce) == "table" and getgenv().settings.helloResponce or splitString(getgenv().settings.helloResponce); reply = r[math.random(#r)]
                elseif string.find(msg, 'bot') then
                    local r = type(getgenv().settings.botResponce) == "table" and getgenv().settings.botResponce or splitString(getgenv().settings.botResponce); reply = r[math.random(#r)]
                elseif string.find(msg, 'donate') then
                    local r = type(getgenv().settings.donateResponce) == "table" and getgenv().settings.donateResponce or splitString(getgenv().settings.donateResponce); reply = r[math.random(#r)]
                elseif string.find(msg, 'scam') then
                    local r = type(getgenv().settings.scamResponce) == "table" and getgenv().settings.scamResponce or splitString(getgenv().settings.scamResponce); reply = r[math.random(#r)]
