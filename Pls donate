local function choosePlaceId()
    if vcEnabled and getgenv().settings.vcServer then return 8943844393
    elseif getgenv().settings.AlternativeHop then return (math.random() < 0.5) and 8943844393 or 8737602449
    else return 8737602449 end
end

local function serverHop()
    while task.wait(1.5) do
        if httprequest then
            task.spawn(function()
                local PlaceId = choosePlaceId()
                local req = httprequest({Url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true", PlaceId)})
                local success, body = pcall(function() return HttpService:JSONDecode(req.Body) end)
                if success and body and body.data then
                    local servers = {}
                    for _, server in pairs(body.data) do
                        if server.playing < 25 and server.id ~= game.JobId and server.playing > 12 then table.insert(servers, server) end
                    end
                    if #servers > 0 then
                        pcall(function() TPService:TeleportToPlaceInstance(PlaceId, servers[math.random(1, #servers)].id, player) end)
                    end
                end
            end)
        end
    end
end

local function splitString(inputstr)
    local t = {}
    for str in string.gmatch(inputstr, "([^,]+)") do table.insert(t, str:match("^%s*(.-)%s*$")) end
    return t
end

local function chat(msg) pcall(function() TextChatService.TextChannels.RBXGeneral:SendAsync(msg) end) end

local function formatNumber(n)
    if n == 420 or n == 425 then n = n + 10 end
    if n >= 10000 then return string.format("%.1fk", n / 1000)
    elseif n >= 1000 then return string.format("%.2fk", n / 1000)
    else return tostring(n) end
end

local function hex(c3)
	local r, g, b = math.floor(c3.R * 255), math.floor(c3.G * 255), math.floor(c3.B * 255)
	return string.format("#%02X%02X%02X", r, g, b)
end

local function rgb(hexStr)
	hexStr = hexStr:gsub("#", "")
	local r, g, b = tonumber("0x" .. hexStr:sub(1, 2)) or 255, tonumber("0x" .. hexStr:sub(3, 4)) or 255, tonumber("0x" .. hexStr:sub(5, 6)) or 255
	return Color3.fromRGB(r, g, b)
end

