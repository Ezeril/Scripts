local function updateBoothText()
    if not getgenv().settings.textUpdateToggle or not _boothlocation or not Remotes then return end
    local currentRaw = tonumber(newRaisedFormat.Value)
    local goalRaw    = currentRaw + tonumber(getgenv().settings.goalBox)
    local text = getgenv().settings.customBoothText:gsub("%%$C", formatNumber(currentRaw)):gsub("%%$G", formatNumber(goalRaw)):gsub("%%$JPR", tostring(getgenv().settings.jumpsPerRobux))
    
    local basePayload = {
        textFont         = Enum.Font.SciFi,
        richText         = true,
        strokeColor      = Color3.new(0, 0, 0),
        strokeOpacity    = 0,
        textColor        = pcall(rgb, getgenv().settings.hexBox) and rgb(getgenv().settings.hexBox) or Color3.new(1,1,1),
        buttonStrokeColor= Color3.new(0, 0, 0),
        buttonTextColor  = Color3.new(1, 1, 1),
        buttonColor      = Color3.new(98/255, 255/255, 0),
        buttonHoverColor = Color3.new(98/255, 255/255, 0),
        buttonLayout     = "",
        text             = text
    }
    pcall(function() Remotes.Event("SetCustomization"):FireServer(basePayload, "booth") end)
end

local function begging()
	while getgenv().settings.autoBeg do
        local msgs = type(getgenv().settings.begMessage) == "table" and getgenv().settings.begMessage or splitString(getgenv().settings.begMessage)
