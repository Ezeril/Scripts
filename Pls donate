        buttonHoverColor = Color3.new(98/255, 255/255, 0), buttonLayout = "", text = text
    }
    pcall(function() Remotes.Event("SetCustomization"):FireServer(basePayload, "booth") end)
end

local function begging()
	while getgenv().settings.autoBeg do
        local msgs = type(getgenv().settings.begMessage) == "table" and getgenv().settings.begMessage or splitString(getgenv().settings.begMessage)
		if #msgs > 0 then chat(msgs[math.random(#msgs)]) end
		task.wait(getgenv().settings.begDelay)
	end
end

local function checkForBots()
	if not getgenv().settings.antiBotServers or not _boothlocation then return end
    local flaggedTexts = {'spin', 'jump', 'helicopter', '+1 speed', 'gifting donations', 'goal'}
    local flaggedTextCount = 0
	local boothUiStuff = _boothlocation:WaitForChild("BoothUI", 5)
	if not boothUiStuff then return end
	for i,v in next, boothUiStuff:GetDescendants() do
		if v:IsA('TextLabel') then
			for _, text in ipairs(flaggedTexts) do
				if string.find(v.Text:lower(), text) and not v:GetAttribute('flaggedtext') then
					flaggedTextCount += 1; v:SetAttribute('flaggedtext',true)
				end
			end
		end
	end
	if flaggedTextCount > 6 then serverHop() end
end

