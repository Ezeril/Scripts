    LoadText.TextColor3 = C.white
    task.wait(0.5)

    -- ON DÉTRUIT L'ÉCRAN DE CHARGEMENT IMMÉDIATEMENT ICI
    LoadFrame:Destroy()
    Win.Visible = true

    -- ==========================================
    --  LOGIQUE EN ARRIÈRE-PLAN (NE BLOQUE PLUS L'UI)
    -- ==========================================
    task.spawn(function()
        -- Récupération silencieuse des Remotes
        for i,v in next, ReplicatedStorage:GetChildren() do
           if v.Name:find('Remote') and v:IsA('ModuleScript') then
               pcall(function() Remotes = require(v) end)
               break
           end
        end

        -- Récupération silencieuse de Leaderstats
        pcall(function() newRaisedFormat = player:WaitForChild('leaderstats', 5):WaitForChild('Raised', 5) end)

        -- Récupération silencieuse de MapUI
        local _shuffled = workspace:FindFirstChild('MapUI')
        if not _shuffled then
            pcall(function() _boothlocation = player.PlayerGui:WaitForChild('MapUIContainer', 5):WaitForChild('MapUI', 5) end)
        else
            _boothlocation = _shuffled
        end

        if not _boothlocation then return end

        -- Recherche de stand vide
        local function findUnclaimed()
            unclaimed = {}
            local boothUI      = _boothlocation:WaitForChild("BoothUI")
            local interactions = workspace:WaitForChild("BoothInteractions")
            local mainPos2D    = Vector3.new(mainCheckPosition.X, 0, mainCheckPosition.Z)

            for _, uiFrame in ipairs(boothUI:GetChildren()) do
                if uiFrame:FindFirstChild("Details") and uiFrame.Details:FindFirstChild("Owner") then
                    if string.find(uiFrame.Details.Owner.Text, player.DisplayName) or string.find(uiFrame.Details.Owner.Text, player.Name) then
                        bclaimed = true
                        local bNum = tonumber(uiFrame.Name:match("%d+"))
                        if bNum then unclaimed[2] = bNum end
                        return true
                    end
                end
            end

            if not bclaimed then
                for _, uiFrame in ipairs(boothUI:GetChildren()) do
                    if uiFrame.Details.Owner.Text == "unclaimed" then
                        local boothNum = tonumber(uiFrame.Name:match("%d+"))
                        if boothNum then
                            for _, interact in ipairs(interactions:GetChildren()) do
                                if interact:GetAttribute("BoothSlot") == boothNum then
                                    local pos2D = Vector3.new(interact.Position.X, 0, interact.Position.Z)
                                    if (pos2D - mainPos2D).Magnitude < 92 then
                                        unclaimed[2] = boothNum
                                        return false
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end

        pcall(findUnclaimed)

        -- Si on a trouvé un stand vide, on le Claim et on Marche
        if unclaimed[2] and not bclaimed then
            pcall(function() Remotes.Event("ClaimBooth"):InvokeServer(unclaimed[2]) end)
            
            pcall(function()
                local theCframe = CFrame.new(0, 0, getgenv().settings.boothPosition)
                local boothPos, mainPosX
                for i, v in ipairs(workspace.BoothInteractions:GetChildren()) do
                    if v:GetAttribute("BoothSlot") == unclaimed[2] then
                        mainPosX = v.CFrame
                        boothPos = v.CFrame * theCframe
                        player.Character.HumanoidRootPart.CFrame = mainPosX
                        break
                    end
                end
                if boothPos then
                    player.Character.Humanoid.WalkSpeed = 32
                    local atBooth = false
                    player.Character.Humanoid:MoveTo(boothPos.Position)
                    local connection = player.Character.Humanoid.MoveToFinished:Connect(function() atBooth = true end)
                    
                    local atboothtick = 0
                    repeat task.wait(); atboothtick += 1; if atboothtick > 999 then break end until atBooth
                    
                    if connection then connection:Disconnect() end
                    player.Character.Humanoid.RootPart.CFrame = CFrame.new(boothPos.Position)
                    player.Character:SetPrimaryPartCFrame(CFrame.new(player.Character.HumanoidRootPart.Position, Vector3.new(40, 14, 101)))
                    task.wait(0.6)
                    player.Character.Humanoid.WalkSpeed = 16
                    bclaimed = true
                end
            end)
        end

        -- Lancement des événements Leaderstats
        if newRaisedFormat then
            local RaisedC = newRaisedFormat.Value
            newRaisedFormat.Changed:Connect(function()
                local raised = newRaisedFormat.Value - RaisedC
                
                if getgenv().settings.spinSet and player.Character:FindFirstChildWhichIsA('Humanoid').RootPart:FindFirstChild('Spin') then
                    local spinPart = player.Character.Humanoid.RootPart:FindFirstChild('Spin')
                    local sSM = getgenv().settings.spinSpeedMultiplier
                    local averageDelta = raised / 3
                    xspin = (averageDelta * sSM) + spinPart.AngularVelocity.Y
                    spinPart.AngularVelocity = Vector3.new(0, xspin, 0)
                end
                
                if getgenv().settings.donationJump then
                    task.spawn(function()
                        for i = 1, raised * getgenv().settings.jumpsPerRobux do
                            player.Character.Humanoid:ChangeState('Jumping')
                            repeat task.wait() until player.Character.Humanoid:GetState() == Enum.HumanoidStateType.Running
                        end
                    end)
                end
                
                if getgenv().settings.autoThanks then
                    task.spawn(function()
                        task.wait(getgenv().settings.thanksDelay)
                        local tMsgs = splitString(getgenv().settings.thanksMessage)
                        if #tMsgs > 0 then chatMsg(tMsgs[math.random(#tMsgs)]) end
                    end)
                end
                
                RaisedC = newRaisedFormat.Value
                task.wait(getgenv().settings.textUpdateDelay)
                updateBoothText()
            end)
            updateBoothText()
        end
    end)
end)

