    box.Size = UDim2.new(1, 0, 0, 45); box.BackgroundColor3 = C.card; box.PlaceholderText = "  " .. placeholder; box.TextColor3 = C.text; box.Font = Enum.Font.GothamSemibold; box.TextSize = 12; box.TextXAlignment = Enum.TextXAlignment.Left; box.ClearTextOnFocus = false; box.TextWrapped = true; corner(box, 9); stroke(box, C.divider, 1)
    
    local val = getgenv().settings[configKey]
    if type(val) == "table" then box.Text = table.concat(val, ", ") else box.Text = tostring(val) end

    box.FocusLost:Connect(function()
        local txt = box.Text
        if type(getgenv().settings[configKey]) == "table" then getgenv().settings[configKey] = splitString(txt) else getgenv().settings[configKey] = txt end
        if callback then callback(txt) end
    end)
    return box
end

