        unclaimed = {}
        for _, ui in ipairs(_boothlocation.BoothUI:GetChildren()) do
            if ui.Details.Owner.Text == "unclaimed" then table.insert(unclaimed, tonumber(ui.Name:match("%d+"))) end
        end
    end

    if not pcall(findUnclaimed) or not unclaimed[1] then serverHop() return end

    local function claim() Remotes.Event("ClaimBooth"):InvokeServer(unclaimed[1]) end
    while not pcall(claim) do table.remove(unclaimed, 1); if #unclaimed == 0 then serverHop() break end; task.wait(1) end

    -- Move to Booth
    local boothPos
    for _, v in ipairs(workspace.BoothInteractions:GetChildren()) do
        if v:GetAttribute("BoothSlot") == unclaimed[1] then boothPos = v.CFrame * CFrame.new(0,0,3); break end
    end
    if boothPos then player.Character.HumanoidRootPart.CFrame = boothPos end
    bclaimed = true

    if getgenv().settings.autoBeg then spamming = task.spawn(begging) end

    -- Donation Tracker
    local stats = player:WaitForChild('leaderstats')
    newRaisedFormat = stats:WaitForChild('Raised')
    local RaisedC = newRaisedFormat.Value

    newRaisedFormat.Changed:Connect(function()
        local raised = newRaisedFormat.Value - RaisedC
        sgoalR = sgoalR + raised
        
        -- Webhook
        sendWebhookDono(raised, "A Donor")

        -- Effects
        if getgenv().settings.spinSet then
            local root = player.Character.HumanoidRootPart
            local spin = root:FindFirstChild("Spin") or Instance.new("BodyAngularVelocity", root)
            spin.Name = "Spin"; spin.MaxTorque = Vector3.new(0, math.huge, 0)
            spin.AngularVelocity += Vector3.new(0, (raised/3) * getgenv().settings.spinSpeedMultiplier, 0)
        end
        if getgenv().settings.donationJump then
            task.spawn(function()
                for i = 1, raised * getgenv().settings.jumpsPerRobux do
                    player.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping); task.wait(0.5)
                end
            end)
        end
        if getgenv().settings.gravitySwitch then workspace.Gravity = workspace.Gravity - raised end
        
        -- Auto Thanks
        if getgenv().settings.autoThanks then
            task.delay(getgenv().settings.thanksDelay, function()
                local msgs = splitStr(getgenv().settings.thanksMessage)
                if #msgs > 0 then chatMsg(msgs[math.random(#msgs)]) end
            end)
        end

        -- Auto Hop
        if getgenv().settings.serverHopAfterDonation or (getgenv().settings.goalServerhopSwitch and sgoalR >= getgenv().settings.goalServerhopGoal) then
            serverHop()
        end

        RaisedC = newRaisedFormat.Value
        task.wait(getgenv().settings.textUpdateDelay); updateBoothText()
    end)
    updateBoothText()
end)

-- Auto Reply Logic
Players.PlayerChatted:Connect(function(_, p, message)
    if not getgenv().settings.autoNearReply or p == player then return end
    if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and player.Character then
        if (p.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude < 15 then
            local msg = string.lower(message)
            local reply = nil
            if msg:find("hello") or msg:find("hi ") then reply = splitStr(getgenv().settings.helloResponce)
            elseif msg:find("bot") then reply = splitStr(getgenv().settings.botResponce)
            elseif msg:find("donate") then reply = splitStr(getgenv().settings.donateResponce)
            elseif msg:find("scam") then reply = splitStr(getgenv().settings.scamResponce)
            elseif not getgenv().settings.autoReplyNoRespond then reply = splitStr(getgenv().settings.otherResponce) end

            if reply and #reply > 0 then task.delay(2 + math.random(), function() chatMsg(reply[math.random(#reply)]) end) end
        end
    end
end)

