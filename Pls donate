                    local r = type(getgenv().settings.otherResponce) == "table" and getgenv().settings.otherResponce or splitString(getgenv().settings.otherResponce); reply = r[math.random(#r)]
                end
                if reply then task.wait(2.1 + math.random()); chatMsg(reply) end
