--  5. EXECUTION & LOGIC (NO FREEZE)
-- ============================================================
task.spawn(function()
    -- ANIMATION LOADING SCREEN
    tween(BarFill, {Size = UDim2.new(0.4, 0, 1, 0)}, 0.6)
    task.wait(0.6)
    LoadText.Text = "Loading Comet Hub..."
    tween(BarFill, {Size = UDim2.new(1, 0, 1, 0)}, 0.6)
    task.wait(0.6)
    
    LoadFrame:Destroy()
    Win.Visible = true

    -- ==========================================
    --  ORIGINAL CLAIM & WALK LOGIC IN BACKGROUND
    -- ==========================================
    task.spawn(function()
        local function findUnclaimed()
            unclaimed = {}
            if not _boothlocation then return end
            local boothUI = _boothlocation:WaitForChild("BoothUI", 5)
            local interactions = workspace:WaitForChild("BoothInteractions", 5)
            if not boothUI or not interactions then return end

            for _, uiFrame in ipairs(boothUI:GetChildren()) do
                if uiFrame.Details.Owner.Text == "unclaimed" then
                    local boothNum = tonumber(uiFrame.Name:match("%d+"))
                    if boothNum then
                        for _, interact in ipairs(interactions:GetChildren()) do
                            if interact:GetAttribute("BoothSlot") == boothNum then
                                local pos2D = Vector3.new(interact.Position.X, 0, interact.Position.Z)
                                if (pos2D - mainCheckPosition).Magnitude < 92 then
                                    table.insert(unclaimed, boothNum)
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end

        pcall(findUnclaimed)

        if unclaimed[1] and Remotes then
            pcall(function() Remotes.Event("ClaimBooth"):InvokeServer(unclaimed[1]) end)

            getgenv().walkToBooth = function()
                local theCframe = CFrame.new(0, 0, getgenv().settings.boothPosition)
                local boothPos, mainPosX
                for i, v in ipairs(workspace.BoothInteractions:GetChildren()) do
                    if v:GetAttribute("BoothSlot") == unclaimed[1] then
                        mainPosX = v.CFrame
                        boothPos = v.CFrame * theCframe
                        player.Character.HumanoidRootPart.CFrame = mainPosX
                        break
                    end
                end
                if boothPos then
                    player.Character.Humanoid.WalkSpeed = 32
                    local atBooth = false
                    player.Character.Humanoid:MoveTo(boothPos.Position)
                    local conn = player.Character.Humanoid.MoveToFinished:Connect(function(reached) atBooth = true end)
                    local atboothtick = 0
                    repeat task.wait(); atboothtick += 1; if atboothtick > 999 then break end until atBooth
                    if conn then conn:Disconnect() end
                    player.Character.Humanoid.RootPart.CFrame = CFrame.new(boothPos.Position)
                    player.Character:SetPrimaryPartCFrame(CFrame.new(player.Character.HumanoidRootPart.Position, Vector3.new(40, 14, 101)))
                    task.wait(0.6)
                    player.Character.Humanoid.WalkSpeed = 16
                    if getgenv().settings.danceChoice ~= "Disabled" then pcall(function() Players:Chat('/e dance' .. getgenv().settings.danceChoice) end) end
                    bclaimed = true
                end
            end
            pcall(getgenv().walkToBooth)
        end

        if getgenv().settings.autoBeg then spamming = task.spawn(begging) end

        -- LEADERSTATS LOGIC
        if newRaisedFormat then
            local RaisedC = newRaisedFormat.Value
            newRaisedFormat.Changed:Connect(function()
                local raised = newRaisedFormat.Value - RaisedC
                
                if getgenv().settings.spinSet and player.Character then
                    local spin = player.Character.Humanoid.RootPart:FindFirstChild('Spin') or Instance.new("BodyAngularVelocity", player.Character.Humanoid.RootPart)
                    spin.Name = "Spin"; spin.MaxTorque = Vector3.new(0, math.huge, 0)
                    xspin = ((raised/3) * getgenv().settings.spinSpeedMultiplier) + (spin.AngularVelocity.Y or 0)
                    spin.AngularVelocity = Vector3.new(0, xspin, 0)
                end
                
                if getgenv().settings.donationJump then
                    task.spawn(function()
                        for i = 1, raised * getgenv().settings.jumpsPerRobux do
                            player.Character.Humanoid:ChangeState('Jumping')
                            task.wait(0.5)
                        end
                    end)
                end
                
                if getgenv().settings.autoThanks then
                    task.spawn(function()
                        task.wait(getgenv().settings.thanksDelay)
                        local tMsgs = type(getgenv().settings.thanksMessage) == "table" and getgenv().settings.thanksMessage or splitString(getgenv().settings.thanksMessage)
                        if #tMsgs > 0 then chatMsg(tMsgs[math.random(#tMsgs)]) end
                    end)
                end

                if getgenv().settings.webhookToggle and getgenv().settings.webhookBox ~= "" then
                    task.spawn(function() oldWebhook(player.Name .. " just got donated " .. tostring(raised) .. " R$!") end)
                end
                
                RaisedC = newRaisedFormat.Value
                task.wait(getgenv().settings.textUpdateDelay)
                updateBoothText()
            end)
            updateBoothText()
        end
    end)
end)

-- AUTO REPLIES
Players.PlayerChatted:Connect(function(_, p, message)
    if not getgenv().settings.autoNearReply or p == player then return end
    local msg = string.lower(message)
    local pChar = p.Character
    if pChar and pChar:FindFirstChild("HumanoidRootPart") and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        if (pChar.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude < 11 then
            local reply = nil
            if string.find(msg, 'hello') or string.find(msg, 'hi ') then
                local r = type(getgenv().settings.helloResponce) == "table" and getgenv().settings.helloResponce or splitString(getgenv().settings.helloResponce); reply = r[math.random(#r)]
            elseif string.find(msg, 'bot') then
                local r = type(getgenv().settings.botResponce) == "table" and getgenv().settings.botResponce or splitString(getgenv().settings.botResponce); reply = r[math.random(#r)]
            elseif string.find(msg, 'donate') then
                local r = type(getgenv().settings.donateResponce) == "table" and getgenv().settings.donateResponce or splitString(getgenv().settings.donateResponce); reply = r[math.random(#r)]
            elseif string.find(msg, 'scam') then
                local r = type(getgenv().settings.scamResponce) == "table" and getgenv().settings.scamResponce or splitString(getgenv().settings.scamResponce); reply = r[math.random(#r)]
            end
            if reply then task.wait(2.1 + math.random()); chatMsg(reply) end
        end
    end
end)

