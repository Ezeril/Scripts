    local active = default
    btn.MouseButton1Click:Connect(function()
        active = not active; tween(dot, {BackgroundColor3 = active and C.toggleOn or C.toggleOff})
        callback(active)
    end)
end

local function makeInput(parent, placeholder, order, defaultVal, callback)
    local box = Instance.new("TextBox", parent)
    box.LayoutOrder = order; box.Size = UDim2.new(1, 0, 0, 36); box.BackgroundColor3 = C.card
    box.PlaceholderText = "  " .. placeholder; box.Text = defaultVal or ""; box.TextColor3 = C.text; box.Font = Enum.Font.GothamSemibold; box.TextSize = 13; box.TextXAlignment = Enum.TextXAlignment.Left; box.ClearTextOnFocus = false; corner(box, 9); stroke(box, C.divider, 1)
    if callback then box.FocusLost:Connect(function() callback(box.Text) end) end
end

local function makeConsole(parent, title, order, defaultTable, callback)
    sectionLabel(parent, title, order)
    local box = Instance.new("TextBox", parent)
    box.LayoutOrder = order+1; box.Size = UDim2.new(1, 0, 0, 80); box.BackgroundColor3 = C.card
    box.Text = table.concat(defaultTable, "\n"); box.TextColor3 = C.text; box.Font = Enum.Font.GothamSemibold; box.TextSize = 12; box.TextXAlignment = Enum.TextXAlignment.Left; box.TextYAlignment = Enum.TextYAlignment.Top; box.MultiLine = true; box.ClearTextOnFocus = false; box.TextWrapped = true; corner(box, 9); stroke(box, C.divider, 1)
    local btn = Instance.new("TextButton", parent); btn.LayoutOrder = order+2; btn.Size = UDim2.new(1, 0, 0, 25); btn.BackgroundColor3 = C.cardHover; btn.Text = "Save " .. title; btn.TextColor3 = C.accent; btn.Font = Enum.Font.GothamBold; btn.TextSize = 12; corner(btn, 6)
    btn.MouseButton1Click:Connect(function()
        local split = {}
        for line in string.gmatch(box.Text, "[^\n]+") do table.insert(split, line) end
        callback(split)
        btn.Text = "Saved!"; task.wait(1); btn.Text = "Save " .. title
    end)
end

local function makeActionBtn(parent, text, order, callback)
    local btn = Instance.new("TextButton", parent); btn.LayoutOrder = order; btn.Size = UDim2.new(1, 0, 0, 36); btn.BackgroundColor3 = C.cardHover; btn.Text = text; btn.TextColor3 = C.accent; btn.Font = Enum.Font.GothamBold; btn.TextSize = 13; corner(btn, 9); stroke(btn, C.divider, 1)
