local function updateBoothText()
    if not Settings.textUpdateToggle or not _boothlocation or not unclaimed[2] or not Remotes then return end
    local currentRaw = tonumber(newRaisedFormat and newRaisedFormat.Value or 0)
    local goalRaw    = currentRaw + tonumber(Settings.goalBox)
    local text = Settings.customBoothText:gsub("%%$C", formatNumber(currentRaw)):gsub("%%$G", formatNumber(goalRaw)):gsub("%%$JPR", tostring(Settings.jumpsPerRobux))

    local basePayload = {
        textFont         = Enum.Font.SciFi,
        richText         = true,
        strokeColor      = Color3.new(0, 0, 0),
        strokeOpacity    = 0,
        textColor        = rgb(Settings.hexBox),
        buttonStrokeColor= Color3.new(0, 0, 0),
        buttonTextColor  = Color3.new(1, 1, 1),
        buttonColor      = Color3.new(98/255, 255/255, 0),
        buttonHoverColor = Color3.new(98/255, 255/255, 0),
        buttonLayout     = "",
        text             = text
    }
    pcall(function() Remotes.Event("SetCustomization"):FireServer(basePayload, "booth") end)
end

local function begging()
    while Settings.autoBeg do
        local msgs = splitString(Settings.begMessage)
        if #msgs > 0 then chatMsg(msgs[math.random(#msgs)]) end
        task.wait(Settings.begDelay)
    end
end

