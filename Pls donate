--  LOGIQUE D'ORIGINE (RÉCUPÉRATION DU STAND)
-- ==========================================
task.spawn(function()
    -- 1. Récupération des remotes
    for i,v in next, ReplicatedStorage:GetChildren() do
        if v.Name:find('Remote') and v.IsA(v, 'ModuleScript') then
            local suc = pcall(function() require(v).Event('PromotionBlimpGiftbux'):FireServer() end)
            if suc then Remotes = require(v); break end
        end
        task.wait()
    end

    -- 2. Trouver le dossier MapUI
    local _shuffled = workspace:WaitForChild('MapUI',3)
    local _shufflerandom = 0
    if not _shuffled then _shufflerandom = 1 end
    if _shufflerandom == 1 then
        pcall(function() _boothlocation = player:WaitForChild('PlayerGui',5):WaitForChild('MapUIContainer',5):WaitForChild('MapUI',5) end)
    else
        _boothlocation = _shuffled or workspace:WaitForChild('MapUI')
    end

    if not _boothlocation then return serverHop() end

    -- 3. Fonction FindUnclaimed Originale
    local function findUnclaimed()
        unclaimed = {}
        local boothUI = _boothlocation:WaitForChild("BoothUI")
        local interactions = workspace:WaitForChild("BoothInteractions")
        local mainPos2D = Vector3.new(mainCheckPosition.X, 0, mainCheckPosition.Z)

        for _, uiFrame in ipairs(boothUI:GetChildren()) do
            if uiFrame.Details.Owner.Text == "unclaimed" then
                local boothNum = tonumber(uiFrame.Name:match("%d+"))
                if boothNum then
                    for _, interact in ipairs(interactions:GetChildren()) do
                        if interact:GetAttribute("BoothSlot") == boothNum then
                            local pos2D = Vector3.new(interact.Position.X, 0, interact.Position.Z)
                            if (pos2D - mainPos2D).Magnitude < 92 then
                                table.insert(unclaimed, boothNum)
                                break
                            end
                        end
                    end
                end
            end
        end
    end

    if not pcall(findUnclaimed) then serverHop() end

    local claimCount = #unclaimed
    if not unclaimed[2] then
       serverHop()
       return
    end

    -- 4. Fonction Boothclaim Originale
    local function boothclaim()
        Remotes.Event("ClaimBooth"):InvokeServer(unclaimed[2])
        if not string.find(_boothlocation.BoothUI:FindFirstChild(tostring("BoothUI" .. unclaimed[2])).Details.Owner.Text, player.DisplayName) then
            task.wait(1)
            if not string.find(_boothlocation.BoothUI:FindFirstChild(tostring("BoothUI" .. unclaimed[2])).Details.Owner.Text, player.DisplayName) then
                error()
            end
        end
    end

    while not pcall(boothclaim) do
        if errCount >= claimCount then serverHop() end
        table.remove(unclaimed, 1)
        errCount = errCount + 1
    end

    -- 5. Fonction WalkToBooth Originale
    getgenv().walkToBooth = function()
        local theCframe
        if string.find(tostring(getgenv().settings.boothPosition), "6") then
            theCframe = CFrame.new(getgenv().settings.boothPosition, 0, 0)
        else
            theCframe = CFrame.new(0, 0, getgenv().settings.boothPosition)
        end
        local boothPos, mainPosX
        for i, v in ipairs(workspace.BoothInteractions:GetChildren()) do
            if v:GetAttribute("BoothSlot") == unclaimed[2] then
                mainPosX = v.CFrame
                boothPos = v.CFrame * theCframe
                player.Character.HumanoidRootPart.CFrame = mainPosX
                break
            end
        end
        player.Character.Humanoid.WalkSpeed = 32
        local atBooth = false
        if workspace.Map.Decoration:FindFirstChild('Benches') then
            workspace.Map.Decoration.Benches:Destroy()		
        end
        player.Character.Humanoid:MoveTo(boothPos.Position)
        player.Character.Humanoid.MoveToFinished:Connect(function(reached)
            atBooth = true
        end)
        local atboothtick = 0
        repeat
            task.wait()
            atboothtick += 1
            if atboothtick > 999 then break end
        until atBooth
        player.Character.Humanoid.RootPart.CFrame = CFrame.new(boothPos.Position)
        player.Character:SetPrimaryPartCFrame(CFrame.new(player.Character.HumanoidRootPart.Position, Vector3.new(40, 14, 101)))
        task.wait(0.6)
        player.Character.Humanoid.WalkSpeed = 16
        Players:Chat('/e dance' .. getgenv().settings.danceChoice)
        bclaimed = true
    end

    walkToBooth()

    if getgenv().settings.autoBeg then
        spamming = task.spawn(begging)
    end

    -- 6. Events de Leaderstats (Tracking)
    local lstats = player:WaitForChild('leaderstats', 5)
    if lstats then 
        newRaisedFormat = lstats:WaitForChild('Raised', 5) 
        if newRaisedFormat then
            local RaisedC = newRaisedFormat.Value
            newRaisedFormat.Changed:Connect(function()
                local raised = newRaisedFormat.Value - RaisedC
                if getgenv().settings.spinSet and player.Character and player.Character.Humanoid.RootPart:FindFirstChild('Spin') then
                    local spin = player.Character.Humanoid.RootPart.Spin
                    spin.AngularVelocity = Vector3.new(0, spin.AngularVelocity.Y + (raised/3)*getgenv().settings.spinSpeedMultiplier, 0)
                end
                if getgenv().settings.donationJump and player.Character then
                    task.spawn(function()
                        for i = 1, raised * getgenv().settings.jumpsPerRobux do
                            player.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                            task.wait(0.5)
                        end
                    end)
                end
                if getgenv().settings.autoThanks then
                    task.spawn(function()
                        task.wait(2)
                        local tMsgs = splitString(getgenv().settings.thanksMessage)
                        if #tMsgs > 0 then chat(tMsgs[math.random(#tMsgs)]) end
                    end)
                end
                RaisedC = newRaisedFormat.Value
                task.wait(2)
                updateBoothText()
            end)
            updateBoothText()
        end
    end
end)

-- Auto Replies
local function handleChat(p, message)
    if not getgenv().settings.autoNearReply or p == player then return end
    local msg = string.lower(message)
    local pChar = p.Character
    if pChar and pChar:FindFirstChild("HumanoidRootPart") and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        if (pChar.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude < 15 then
            local reply = nil
            if string.find(msg, 'hello') or string.find(msg, 'hi ') then
                local resps = splitString(getgenv().settings.helloResponce)
                reply = resps[math.random(#resps)]
            elseif string.find(msg, 'bot') then
                local resps = splitString(getgenv().settings.botResponce)
                reply = resps[math.random(#resps)]
            elseif string.find(msg, 'donate') then
                local resps = splitString(getgenv().settings.donateResponce)
                reply = resps[math.random(#resps)]
            end
            if reply then task.wait(2); chat(reply) end
        end
    end
end

for _, p in pairs(Players:GetPlayers()) do p.Chatted:Connect(function(msg) handleChat(p, msg) end) end
Players.PlayerAdded:Connect(function(p) p.Chatted:Connect(function(msg) handleChat(p, msg) end) end)

