local function makeToggle(parent, text, defaultState, configKey, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, 0, 0, 42); btn.BackgroundColor3 = C.card; btn.Text = "   " .. text; btn.TextColor3 = C.text; btn.Font = Enum.Font.GothamSemibold; btn.TextSize = 13; btn.TextXAlignment = Enum.TextXAlignment.Left
    corner(btn, 9); stroke(btn, C.divider, 1)
    local dot = Instance.new("Frame", btn); dot.Size = UDim2.new(0, 10, 0, 10); dot.Position = UDim2.new(1, -20, 0.5, -5); corner(dot, 10)
    
    local active = defaultState
    dot.BackgroundColor3 = active and C.toggleOn or C.toggleOff

    btn.MouseButton1Click:Connect(function()
        active = not active
        tween(dot, {BackgroundColor3 = active and C.toggleOn or C.toggleOff})
        if configKey then getgenv().settings[configKey] = active end
        if callback then callback(active) end
    end)
end

local function makeInput(parent, placeholder, defaultText, configKey, callback)
    local box = Instance.new("TextBox", parent)
    box.Size = UDim2.new(1, 0, 0, 45); box.BackgroundColor3 = C.card; box.PlaceholderText = "  " .. placeholder; box.Text = defaultText or ""; box.TextColor3 = C.text
    box.Font = Enum.Font.GothamSemibold; box.TextSize = 12; box.TextXAlignment = Enum.TextXAlignment.Left
    box.ClearTextOnFocus = false; box.TextWrapped = true
    corner(box, 9); stroke(box, C.divider, 1)
    
    box.FocusLost:Connect(function()
        if configKey then getgenv().settings[configKey] = box.Text end
        if callback then callback(box.Text) end
    end)
    return box
end

local function updateBoothText()
    if not getgenv().settings.textUpdateToggle or not _boothlocation or not unclaimed[2] or not Remotes or not newRaisedFormat then return end

    local currentRaw = tonumber(newRaisedFormat.Value) or 0
    local goalRaw    = currentRaw + tonumber(getgenv().settings.goalBox)
    local text = getgenv().settings.customBoothText:gsub("%%$C", formatNumber(currentRaw)):gsub("%%$G", formatNumber(goalRaw)):gsub("%%$JPR", tostring(getgenv().settings.jumpsPerRobux))

    local basePayload = {
        textFont         = Enum.Font[getgenv().settings.fontFace] or Enum.Font.SciFi,
        richText         = true, strokeColor = Color3.new(0, 0, 0), strokeOpacity = 0,
        textColor        = pcall(rgb, getgenv().settings.hexBox) and rgb(getgenv().settings.hexBox) or Color3.new(1,1,1),
        buttonStrokeColor= Color3.new(0, 0, 0), buttonTextColor = Color3.new(1, 1, 1),
        buttonColor      = Color3.new(98/255, 255/255, 0), buttonHoverColor = Color3.new(98/255, 255/255, 0),
        buttonLayout     = "", text = text
    }
    pcall(function() Remotes.Event("SetCustomization"):FireServer(basePayload, "booth") end)
end

