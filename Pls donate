function forceServerHop()
	if not httprequest then return end
	local gameId = "8737602449"
	local servers = {}
	local ok, response = pcall(function()
		return httprequest({ Url = "https://games.roblox.com/v1/games/" .. gameId .. "/servers/Public?sortOrder=Desc&limit=100" })
	end)
	if ok and response then
		local okD, body = pcall(function() return httpservice:JSONDecode(response.Body) end)
		if okD and body and body.data then
			for _, v in next, body.data do
				if type(v) == "table" and tonumber(v.playing) and tonumber(v.maxPlayers) and v.playing > 19 then
					table.insert(servers, 1, v.id)
				end
			end
		end
	end
	task.spawn(function()
		while task.wait(0.5) do
			if #servers > 0 then
				pcall(function() TPService:TeleportToPlaceInstance(gameId, servers[math.random(1, #servers)], Players.LocalPlayer) end)
			end
		end
	end)
end

