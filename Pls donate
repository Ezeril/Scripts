local function updateBoothText()
    if not getgenv().settings.textUpdateToggle or not _boothlocation or not Remotes then return end
    local currentRaw = tonumber(newRaisedFormat.Value)
    local goalRaw    = currentRaw + tonumber(getgenv().settings.goalBox)
    local text = getgenv().settings.customBoothText:gsub("%%$C", formatNumber(currentRaw)):gsub("%%$G", formatNumber(goalRaw)):gsub("%%$JPR", tostring(getgenv().settings.jumpsPerRobux))
    
    local font = Enum.Font[getgenv().settings.fontFace] or Enum.Font.SciFi
    local basePayload = {
        textFont = font, richText = true, strokeColor = Color3.new(0, 0, 0), strokeOpacity = 0,
        textColor = rgb(getgenv().settings.hexBox), buttonStrokeColor = Color3.new(0, 0, 0),
