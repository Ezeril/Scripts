local function formatNumber(n)
    if n >= 10000 then return string.format("%.1fk", n / 1000)
    elseif n >= 1000 then return string.format("%.2fk", n / 1000)
    else return tostring(n) end
end

local function serverHop()
    local placeId = (getgenv().settings.vcServer) and 8943844393 or 8737602449
    if getgenv().settings.AlternativeHop then placeId = (math.random() < 0.5) and 8943844393 or 8737602449 end
    if httprequest then
        task.spawn(function()
            local req = httprequest({Url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"})
            local body = HttpService:JSONDecode(req.Body)
            if body and body.data then
                local servers = {}
                for _, s in pairs(body.data) do if s.playing < 25 and s.id ~= game.JobId and s.playing > 12 then table.insert(servers, s) end end
                if #servers > 0 then TPService:TeleportToPlaceInstance(placeId, servers[math.random(#servers)].id, player) end
            end
        end)
    end
end

local function updateBoothText()
    if not getgenv().settings.textUpdateToggle or not _boothlocation then return end
    local currentRaw = tonumber(newRaisedFormat.Value) or 0
    local goalRaw = currentRaw + tonumber(getgenv().settings.goalBox)
    local text = getgenv().settings.customBoothText:gsub("%%$C", formatNumber(currentRaw)):gsub("%%$G", formatNumber(goalRaw)):gsub("%%$JPR", tostring(getgenv().settings.jumpsPerRobux))
    
    local payload = {
        textFont = Enum.Font[getgenv().settings.fontFace] or Enum.Font.SciFi, richText = true,
        strokeColor = Color3.new(0,0,0), strokeOpacity = 0, textColor = Color3.fromHex(getgenv().settings.hexBox:gsub("#","")),
        buttonStrokeColor = Color3.new(0,0,0), buttonTextColor = Color3.new(1,1,1), buttonColor = Color3.new(0.38,1,0),
        buttonHoverColor = Color3.new(0.38,1,0), buttonLayout = "", text = text
    }
    pcall(function() Remotes.Event("SetCustomization"):FireServer(payload, "booth") end)
end

