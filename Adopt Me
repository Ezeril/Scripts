local keywordMap = {
    { p={"school","class","ecole","nursery"},           h="school"    },
    { p={"pet_school","petschool"},                     h="pet_school"},
    { p={"playground","play","swing","slide"},          h="playground"},
    { p={"hospital","sick","heal","doctor","malade"},   h="hospital"  },
    { p={"feed","food","eat","hungry","nourri"},        h="feed_pet"  },
    { p={"water","drink","soif","thirst"},              h="water_pet" },
    { p={"pizza"},                                      h="pizza"     },
    { p={"salon","bath","groom","hair"},                h="salon"     },
}
local function resolveHandler(id)
    local low = id:lower()
    for _, e in ipairs(keywordMap) do
        for _, pat in ipairs(e.p) do
            if low:find(pat) then return QH[e.h], e.h end
        end
    end
    return nil, "unknown"
end

-- ── AUTO QUEST FARM ───────────────────────────────────────────
local _questLoop  = false
local _questDelay = 5
local _skipDone   = true

local function runQuestFarm()
    local quests = getActiveQuests()
    if #quests == 0 then
        notify("Quêtes", "Aucune quête → Debug > Probe Router", 5)
        return
    end
    for _, q in ipairs(quests) do
        if not _questLoop then break end
        local state = tostring(q.state or ""):lower()
        local handler, hName = resolveHandler(q.id)
        print(("[VHub] %-35s | %-12s | %s"):format(q.id, state, hName))
        if _skipDone and (state:find("complet") or state:find("claimed") or state:find("done")) then
            -- skip
        else
            if handler then
                local ok, err = pcall(handler)
                notify(ok and "✅" or "❌", q.id:sub(1,25), 2)
                if not ok then warn("[VHub] Handler:", err) end
            else
                notify("❓", "No handler: "..q.id:sub(1,20), 3)
            end
            task.wait(_questDelay)
        end
    end
end

