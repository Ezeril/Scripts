-- ──────────────────── Recherche de remote ──────────────────
-- Cherche recursivement dans API par nom exact ou partiel
local remoteCache = {}
local function findRemote(name, searchFolder)
    if remoteCache[name] then return remoteCache[name] end
    local folder = searchFolder or API
    if not folder then return nil end
    -- Cherche exact
    local r = folder:FindFirstChild(name)
    if r then remoteCache[name] = r return r end
    -- Cherche recursif
    for _, child in ipairs(folder:GetDescendants()) do
        if child.Name == name then
            remoteCache[name] = child
            return child
        end
    end
    return nil
end

-- Cherche par mot-cle partiel (pour retrouver les remotes renommees)
local function findRemotePartial(keyword)
    if not API then return nil end
    for _, child in ipairs(API:GetDescendants()) do
        if child.Name:lower():find(keyword:lower()) then
            return child
        end
    end
    return nil
end

-- ──────────────────── Detection auto des remotes ───────────
-- La remote de nourriture change souvent de nom
-- On cherche par pattern connu
local foodRemote = nil
local useBlockRemote = nil

local function detectRemotes()
    if not API then return end
    -- Cherche la remote nourriture (longue chaine de lettres = remote obfusquee)
    for _, child in ipairs(API:GetChildren()) do
        if child.ClassName == "RemoteFunction" then
            -- Les remotes obfusquees ont des noms > 10 chars aleatoires
            if #child.Name > 10 and child.Name:match("^[a-zA-Z]+$") then
                -- Teste si c'est la remote food en l'invoquant avec args connus
                local ok = pcall(function()
                    child:InvokeServer("food", "cafeteria_sandwich", { buy_count = 0 })
                end)
                if ok then
                    foodRemote = child
                    print("[VHub] Remote food trouvee:", child.Name)
                end
                -- Teste UseBlock
                local ok2 = pcall(function()
                    child:InvokeServer("test", "UseBlock", nil, nil)
                end)
                if ok2 then
                    useBlockRemote = child
                    print("[VHub] Remote UseBlock trouvee:", child.Name)
                end
            end
        end
    end
    -- Fallback : prend la premiere RemoteFunction avec nom long
    if not foodRemote then
        for _, child in ipairs(API:GetChildren()) do
            if child.ClassName == "RemoteFunction" and #child.Name > 15 then
                foodRemote = child
                useBlockRemote = child
                print("[VHub] Remote fallback:", child.Name)
                break
            end
        end
    end
end

-- ──────────────────── Utilitaires ──────────────────────────
local function tp(cf)
    local c = LP.Character
    if c and c:FindFirstChild("HumanoidRootPart") then
        c.HumanoidRootPart.CFrame = cf
    end
end

local function invokeFood(cat, id, count)
    if not foodRemote then
        detectRemotes()
    end
    if not foodRemote then
        warn("[VHub] Remote food introuvable")
        return false
    end
    local ok, res = pcall(function()
        return foodRemote:InvokeServer(cat, id, { buy_count = count or 1 })
    end)
    if not ok then warn("[VHub] invokeFood error:", res) end
    return ok
end

local function invokeUseBlock(itemId, petModel)
    if not useBlockRemote then detectRemotes() end
    if not useBlockRemote then warn("[VHub] Remote UseBlock introuvable") return false end
    local ok, res = pcall(function()
        return useBlockRemote:InvokeServer(itemId, "UseBlock", nil, petModel)
    end)
    if not ok then warn("[VHub] invokeUseBlock error:", res) end
    return ok
end

local function safeInvoke(remoteName, ...)
    local r = findRemote(remoteName)
    if not r then warn("[VHub] Remote introuvable:", remoteName) return end
    local args = {...}
    local ok, res = pcall(function() return r:InvokeServer(table.unpack(args)) end)
    if not ok then warn("[VHub] Erreur:", remoteName, res) end
    return ok and res or nil
end

local function notify(title, msg, t)
    OrionLib:MakeNotification({
        Name = title, Content = msg,
        Image = "rbxassetid://4483345998", Time = t or 3
    })
end

local function getPet()
    local chars = WS:FindFirstChild("PlayerCharacters")
    return chars and chars:FindFirstChild(LP.Name) or nil
end

local function safeFsys(moduleName)
    local ok1, Fsys = pcall(function()
        return require(RS:WaitForChild("Fsys", 5)).load
    end)
    if not ok1 or not Fsys then return nil, "Fsys indisponible" end
    local ok2, mod = pcall(function() return Fsys(moduleName) end)
    if not ok2 or not mod then return nil, moduleName .. " indisponible" end
    return mod, nil
end

