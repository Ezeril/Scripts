local R = {
    food   = nil,   -- InvokeServer("food","cafeteria_sandwich",{buy_count=0}) → res == 1
    router = nil,   -- InvokeServer("food",...) → res == "food" (string echo)
    money  = nil,   -- InvokeServer() → res == number (balance)
