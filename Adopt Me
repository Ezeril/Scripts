-- ── HOOK REMOTES (capture les invocations du jeu lui-même) ───
local function hookRemotes()
    -- Nécessite un executor supportant getrawmetatable / setreadonly
    local ok = pcall(function()
        local mt = getrawmetatable(game)
        local oldIndex = mt.__index
        setreadonly(mt, false)
        mt.__index = newcclosure(function(self, key)
            if key == "InvokeServer" and self:IsA("RemoteFunction") then
                if self:IsDescendantOf(API) then
                    if not Remotes.allFound[self.Name] then
                        Remotes.allFound[self.Name] = self
                        print("[VHub HOOK] Remote capturée:", self.Name)
                    end
                end
            end
            return oldIndex(self, key)
        end)
        setreadonly(mt, true)
    end)
    if not ok then print("[VHub] Hook non supporté, scan classique utilisé") end
end

-- ── SCAN CLASSIQUE (fallback + init) ─────────────────────────
local function scanRemotes()
    if not API then return end
    for _, child in ipairs(API:GetDescendants()) do
        if child:IsA("RemoteFunction") or child:IsA("RemoteEvent") then
            Remotes.allFound[child.Name] = child
        end
    end
    -- Identification heuristique par test d'invocation
    if not Remotes.food then
        for _, child in ipairs(API:GetChildren()) do
            if child:IsA("RemoteFunction") and #child.Name > 15 then
                local ok = pcall(function()
                    child:InvokeServer("food", "cafeteria_sandwich", { buy_count = 0 })
                end)
                if ok then
                    Remotes.food = child
                    Remotes.useBlock = child
                    print("[VHub SCAN] Remote principale (obf):", child.Name)
                    break
                end
            end
        end
    end
end

-- ── FSYS LOADER ──────────────────────────────────────────────
local function loadFsys(moduleName)
    local ok1, Fsys = pcall(function()
        return require(RS:WaitForChild("Fsys", 5)).load
    end)
    if not ok1 or not Fsys then return nil, "Fsys indisponible" end
    local ok2, mod = pcall(function() return Fsys(moduleName) end)
    return (ok2 and mod) and mod or nil, ok2 and "ok" or moduleName .. " introuvable"
end

-- ── GUIDE / QUEST CLIENT ──────────────────────────────────────
-- Adopt Me a renommé le système en "Guide" (Dec 2025)
-- On essaie tous les noms possibles
local GuideClient = nil
local GUIDE_CANDIDATES = {
    "GuideClient", "QuestClient", "DailiesClient",
    "TaskClient",  "MissionClient", "ChallengeClient",
    "GuideManager","QuestManager",  "TaskBoardClient"
}

local function initGuideClient()
    for _, name in ipairs(GUIDE_CANDIDATES) do
        local mod, _ = loadFsys(name)
        if mod then
            GuideClient = mod
            print("[VHub] Module quêtes trouvé:", name)
            return GuideClient
        end
    end
    warn("[VHub] Aucun module quêtes trouvé (utiliser Debug > Dump Fsys)")
    return nil
end

-- Récupère les quêtes/tâches actives (compatible ancienne + nouvelle structure)
local function getActiveQuests()
    if not GuideClient then initGuideClient() end
    if not GuideClient then return {} end

    local quests = {}
    pcall(function()
        -- Essai de récupérer le manager
        local manager = nil
        for _, method in ipairs({ "get_manager", "GetManager", "getManager" }) do
            if GuideClient[method] then
                manager = GuideClient[method]()
                break
            end
        end
        if not manager then
            -- Certains modules exposent directement les données
            manager = GuideClient
        end

        -- Structure A: guide_entries (Guide system Dec 2025)
        for entryId, entry in pairs(manager.guide_entries or manager.entries or {}) do
            table.insert(quests, {
                id       = tostring(entryId),
                state    = entry.state or entry.completion_state or "active",
                progress = entry.progress or 0,
                data     = entry,
            })
        end

        -- Structure B: serialized_tabs (anciens Dailies/Task Board)
        for tabKind, tab in pairs(manager.serialized_tabs or {}) do
            for qId, data in pairs(tab.active_quests or tab.active_dailies or {}) do
                table.insert(quests, {
                    id       = tostring(qId),
                    tabKind  = tabKind,
                    state    = data.state or "active",
                    progress = data.progress or 0,
                    data     = data,
                })
            end
        end

        -- Structure C: tasks (Task Board Christmas 2025)
        for taskId, task in pairs(manager.tasks or manager.active_tasks or {}) do
            table.insert(quests, {
                id    = tostring(taskId),
                state = task.completed and "completed" or "active",
                data  = task,
            })
        end
    end)
    return quests
end

