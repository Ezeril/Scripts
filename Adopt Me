        c.HumanoidRootPart.CFrame = cf
    end
    if w then task.wait(w) end
end

local function notify(title, msg, t)
    OrionLib:MakeNotification({
        Name = title, Content = msg,
        Image = "rbxassetid://4483345998", Time = t or 3
    })
end

local function buyFood(cat, id, count)
    if not R.food then detectRemotes() end
    if not R.food then
        -- Fallback: essaie le routeur
        if R.router then
            local ok, res = pcall(function()
                return R.router:InvokeServer(cat, id, { buy_count = count or 1 })
            end)
            return ok
        end
        warn("[VHub] ❌ Remote food introuvable")
        return false
    end
    local ok, res = pcall(function()
        return R.food:InvokeServer(cat, id, { buy_count = count or 1 })
    end)
    if ok then print("[VHub] Food bought:", id, "res:", tostring(res)) end
    return ok
end

local function fireNearbyPrompts(radius, max)
    local c = LP.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    if not hrp then return 0 end
    local n = 0
    for _, obj in ipairs(WS:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            local p = obj.Parent
            if p and p:IsA("BasePart") and (hrp.Position-p.Position).Magnitude < (radius or 20) then
                pcall(function() fireproximityprompt(obj) end)
                n = n + 1; task.wait(0.3)
                if max and n >= max then break end
            end
        end
    end
    return n
end

