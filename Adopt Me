-- ── DÉTECTION PAR SIGNATURE ───────────────────────────────────
local function detectRemotes()
    if not API then return end
    print("[VHub] Scan des remotes en cours...")

    for _, remote in ipairs(API:GetDescendants()) do
        if remote:IsA("RemoteFunction") then

            -- Test food buy (signature: retourne 1 ou un nombre entier)
            if not R.food then
                local ok, res = pcall(function()
                    return remote:InvokeServer("food", "cafeteria_sandwich", { buy_count = 0 })
                end)
                if ok and type(res) == "number" and res >= 1 and math.floor(res) == res then
                    R.food = remote
                    print("[VHub] ✅ FOOD remote:", remote.Name, "res:", res)
                end
            end

            -- Test router (signature: retourne la string de l'action)
            if not R.router then
                local ok, res = pcall(function()
                    return remote:InvokeServer("food", "cafeteria_sandwich", { buy_count = 0 })
                end)
                if ok and res == "food" then
                    R.router = remote
                    print("[VHub] ✅ ROUTER remote:", remote.Name)
                end
            end

            -- Test money (signature: retourne un float entre 0 et 1 ou grand nombre)
            if not R.money then
                local ok, res = pcall(function()
                    return remote:InvokeServer()
                end)
                if ok and type(res) == "number" and res > 0 and res < 1 then
                    R.money = remote
                    print("[VHub] ✅ MONEY remote:", remote.Name, "balance:", res)
                end
            end

            -- Stop si on a tout trouvé
            if R.food and R.router and R.money then break end
            task.wait(0.05)
        end
    end

    print("[VHub] Résultat scan:")
    print("  Food  :", R.food   and R.food.Name   or "❌ NON TROUVÉ")
    print("  Router:", R.router and R.router.Name or "❌ NON TROUVÉ")
    print("  Money :", R.money  and R.money.Name  or "❌ NON TROUVÉ")
end

-- ── QUEST DATA ────────────────────────────────────────────────
-- Le routeur accepte "get_quests" — on essaie différentes combinaisons d'args
-- pour obtenir les données réelles
local function fetchQuestData()
    if not R.router then return nil end

    local attempts = {
        -- Différentes signatures possibles pour get_quests
        { "get_quests" },
        { "get_quests", LP.UserId },
        { "get_quests", LP.Name },
        { "get_quests", nil, "guide" },
        { "get_quests", {}, "guide" },
        { "guide", "get_quests" },
        { "guide_tasks" },
        { "get_tasks" },
        { "tasks" },
    }

    for _, args in ipairs(attempts) do
        local ok, res = pcall(function()
            return R.router:InvokeServer(table.unpack(args))
        end)
        if ok and type(res) == "table" then
            print("[VHub] ✅ Quest data trouvée avec args:", table.concat(
                (function()
                    local s = {}
                    for _, v in ipairs(args) do s[#s+1] = tostring(v) end
                    return s
                end)(), ", "
            ))
            return res
        end
        -- Log pour debug
        local argStr = table.concat((function()
            local s = {}
            for _, v in ipairs(args) do s[#s+1] = tostring(v) end
            return s
        end)(), ",")
        print(("[VHub QUEST] args(%s) → ok:%s res:%s"):format(
            argStr, tostring(ok), tostring(res)
        ))
        task.wait(0.1)
    end

    -- Essai avec la food remote aussi
    if R.food then
        for _, cmd in ipairs({"get_quests","guide","tasks","get_tasks"}) do
            local ok, res = pcall(function()
                return R.food:InvokeServer(cmd)
            end)
            if ok and type(res) == "table" then
                print("[VHub] ✅ Quest via food remote:", cmd)
                return res
            end
        end
    end

    return nil
end

-- ── CHERCHER DANS LES MODULES CLIENT ─────────────────────────
-- Plan B: le Guide system stocke les quêtes dans un module client local
local function findQuestsInModules()
    local quests = {}

    -- Cherche dans tous les LocalScripts et ModuleScripts actifs
    -- Le Guide/Quest state est souvent dans un BindableEvent ou une valeur

    -- 1. Cherche les BindableEvents liés aux quêtes
    local function searchFolder(parent, depth)
        if depth > 4 then return end
        local ok, children = pcall(function() return parent:GetChildren() end)
        if not ok then return end
        for _, child in ipairs(children) do
            local name = child.Name:lower()
            if name:find("quest") or name:find("guide") or name:find("task") or name:find("daily") then
                print(("[VHub MODULE] %-15s %-25s @ %s"):format(
                    child.ClassName, child.Name, child:GetFullName()
                ))
                -- Si c'est un ModuleScript, essaie de le require
                if child:IsA("ModuleScript") then
                    local ok2, mod = pcall(require, child)
                    if ok2 and type(mod) == "table" then
                        print("[VHub] ✅ Module quêtes require OK:", child.Name)
                        for k, v in pairs(mod) do
                            print(("  .%-20s = %s"):format(k, type(v)))
                        end
                        -- Essaie de trouver les quêtes actives dedans
                        for _, key in ipairs({"get_active","active","quests","tasks","entries"}) do
                            if type(mod[key]) == "function" then
                                local ok3, data = pcall(mod[key], mod)
                                if ok3 and type(data) == "table" then
                                    print("[VHub] ✅✅ Quêtes actives via ." .. key)
                                    for id, v in pairs(data) do
                                        print("  QUEST:", id, type(v))
                                        table.insert(quests, { id = tostring(id), data = v })
                                    end
                                end
                            end
                        end
                    end
                end
            end
            searchFolder(child, depth + 1)
        end
    end

    -- Scan RS
    searchFolder(RS, 0)
    -- Scan PlayerGui (certains modules sont là)
    local pg = LP:FindFirstChild("PlayerGui")
    if pg then searchFolder(pg, 0) end

    return quests
end

-- ── GET ACTIVE QUESTS (toutes méthodes) ──────────────────────
local function getActiveQuests()
    print("[VHub] Récupération des quêtes...")

    -- Méthode 1: via le routeur remote
    local data = fetchQuestData()
    if data then
        local quests = {}
        -- Parcourt la structure retournée
        local function parseQuestData(t, depth)
            if depth > 3 then return end
            for k, v in pairs(t) do
                if type(v) == "table" then
                    -- Cherche les patterns de quête (id + state)
                    if v.id or v.quest_id or v.task_id then
                        local id = tostring(v.id or v.quest_id or v.task_id)
                        table.insert(quests, {
                            id    = id,
                            state = tostring(v.state or v.status or "active"),
                            data  = v,
                        })
                        print("[VHub QUEST]", id, "state:", v.state or v.status)
                    else
                        -- Peut-être que k est l'id
                        if type(k) == "string" and #k > 3 then
                            table.insert(quests, {
                                id    = k,
                                state = tostring(v.state or v.status or "active"),
                                data  = v,
                            })
                            print("[VHub QUEST]", k, "→", type(v))
                        end
                        parseQuestData(v, depth + 1)
                    end
                end
            end
        end
        parseQuestData(data, 0)
        if #quests > 0 then return quests end
    end

    -- Méthode 2: modules client
    local modQuests = findQuestsInModules()
    if #modQuests > 0 then return modQuests end

    print("[VHub] ❌ Aucune quête trouvée — utilise Debug > Probe Router")
    return {}
end

