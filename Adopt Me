-- Fire les ProximityPrompts dans un rayon donné autour du joueur
local function fireNearbyPrompts(radius, maxCount)
    local char = LP.Character
    if not char then return 0 end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return 0 end
    local count = 0
    for _, obj in ipairs(WS:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            local part = obj.Parent
            if part and part:IsA("BasePart") then
                if (hrp.Position - part.Position).Magnitude < (radius or 20) then
                    pcall(function() fireproximityprompt(obj) end)
                    count = count + 1
                    task.wait(0.3)
                    if maxCount and count >= maxCount then break end
                end
            end
        end
    end
    return count
end

local function invokeFood(cat, id, count)
    if not Remotes.food then scanRemotes() end
    if not Remotes.food then
        warn("[VHub] Remote food introuvable")
        return false
    end
    local ok, res = pcall(function()
        return Remotes.food:InvokeServer(cat, id, { buy_count = count or 1 })
    end)
    if not ok then warn("[VHub] invokeFood:", res) end
    return ok
end

