-- Fix #1 : URL Orion avec fallback automatique
local OrionLib
local urls = {
    "https://raw.githubusercontent.com/nicosanto/Orion/main/source",
    "https://raw.githubusercontent.com/jensonhirst/Orion/main/source",
}
for _, url in ipairs(urls) do
    local ok, result = pcall(function()
        OrionLib = loadstring(game:HttpGet(url))()
    end)
    if ok and OrionLib then break end
end
if not OrionLib then
    error("[VHub] Impossible de charger Orion Library. Verifie ta connexion.")
end

