--  TAB 2 — AUTO FARM
-- ================================================================
local autoTpRunning = false
local autoTpDelay   = 3
local autoFeedOn    = false
local autoFeedDelay = 5

AutoTab:AddSection({ Name = "Auto Teleport" })

AutoTab:AddSlider({
    Name      = "Delai entre teleports (s)",
    Min       = 1,
    Max       = 15,
    Default   = 3,
    Color     = Color3.fromRGB(100, 200, 255),
    Increment = 1,
    ValueName = "s",
    Callback  = function(v) autoTpDelay = v end
})

AutoTab:AddToggle({
    Name    = "Activer Auto Teleport",
    Default = false,
    Flag    = "autotp",
    Save    = true,
    Callback = function(enabled)
        autoTpRunning = enabled
        if enabled then
            notify("Auto Farm", "Demarre !", 2)
            task.spawn(function()
                -- Fix : on copie la liste une seule fois, pas a chaque iteration
                local list = {}
                for _, cf in pairs(locations) do
                    list[#list + 1] = cf
                end
                local i = 1
                while autoTpRunning do
                    tp(list[i])
                    i = (i % #list) + 1
                    task.wait(autoTpDelay)
                end
            end)
        else
            notify("Auto Farm", "Arrete.", 2)
        end
    end
})

AutoTab:AddSection({ Name = "Auto Nourriture" })

AutoTab:AddSlider({
    Name      = "Delai entre repas (s)",
