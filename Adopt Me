-- ── RÉSOLUTION DU TYPE DE QUÊTE ───────────────────────────────
local keywordMap = {
    { patterns = { "school", "class", "ecole", "nursery" },         handler = "school"    },
    { patterns = { "pet_school", "petschool", "pet school" },        handler = "pet_school"},
    { patterns = { "playground", "play", "swing", "slide" },         handler = "playground"},
    { patterns = { "hospital", "sick", "heal", "doctor", "malade" }, handler = "hospital"  },
    { patterns = { "feed", "food", "eat", "hungry", "nourri" },      handler = "feed_pet"  },
    { patterns = { "water", "drink", "soif", "thirst" },             handler = "water_pet" },
    { patterns = { "pizza" },                                         handler = "pizza"     },
    { patterns = { "salon", "bath", "groom", "hair" },               handler = "salon"     },
}

local function resolveHandler(questId)
    local id = questId:lower()
    for _, entry in ipairs(keywordMap) do
        for _, pat in ipairs(entry.patterns) do
            if id:find(pat) then
                return questHandlers[entry.handler], entry.handler
            end
        end
    end
    return nil, "unknown"
end

-- ── AUTO QUEST FARM LOOP ──────────────────────────────────────
local _autoQuestLoop  = false
local _autoQuestDelay = 5
local _skipCompleted  = true

local function runQuestFarm()
    local quests = getActiveQuests()
    if #quests == 0 then
        print("[VHub] Aucune quête active détectée.")
        notify("Quêtes", "Aucune quête trouvée → voir Debug", 4)
        return
    end

    print(("[VHub] %d quête(s) détectée(s)"):format(#quests))

    for _, quest in ipairs(quests) do
        if not _autoQuestLoop then break end

        local state = tostring(quest.state or ""):lower()
        if _skipCompleted and (state == "completed" or state == "claimed" or state == "done") then
            print("[VHub] SKIP (complétée):", quest.id)
        else
            local handler, handlerName = resolveHandler(quest.id)
            print(("[VHub] Quête: %s → handler: %s"):format(quest.id, handlerName))

            if handler then
                local ok, err = pcall(handler)
                if ok then
                    notify("Quest ✅", quest.id:sub(1, 25), 2)
                else
                    warn("[VHub] Erreur handler:", handlerName, err)
                end
            else
                print("[VHub] Pas de handler → ID complet:", quest.id)
                notify("Quest ❓", "No handler: " .. quest.id:sub(1, 20), 3)
            end

            task.wait(_autoQuestDelay)
        end
    end
end

